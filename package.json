{
  "name": "peekle-monorepo",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.0.0",
    "turbo": "^2.3.3"
  },
  "pnpm": {
    "overrides": {
      "dompurify": "^3.3.2",
      "svgo": "^3.3.3",
      "picomatch": "^4.0.4",
      "yaml": "^2.8.3",
      "flatted": "^3.4.2",
      "ajv": "^6.14.0",
      "minimatch": "^3.1.4",
      "brace-expansion": "^1.1.13"
    }
  },
  "packageManager": "pnpm@10.28.1",
  "lint-staged": {
    "apps/frontend/**/*.{ts,tsx}": [
      "pnpm --filter frontend exec eslint --fix",
      "pnpm --filter frontend exec prettier --write"
    ]
  }
}
